# ═══════════════════════════════════════════════════════════════════════════
# RobustIDPS.ai — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your production values:
#   cp .env.example .env
#   nano .env

# ── Database ──────────────────────────────────────────────────────────────
# Development (SQLite):
# DATABASE_URL=sqlite:///./robustidps.db
# Production (PostgreSQL):
DATABASE_URL=postgresql://robustidps:CHANGE_THIS_PASSWORD@postgres:5432/robustidps

# ── Authentication ────────────────────────────────────────────────────────
# CRITICAL: Change this to a random 64-character string in production
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET

# JWT token expiry (minutes). Default 480 = 8 hours
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Default Admin Account ─────────────────────────────────────────────────
# Created automatically on first startup if no users exist
ADMIN_EMAIL=admin@robustidps.ai
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD

# ── Security ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://robustidps.ai

# Rate limits (format: "count/period")
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_HEAVY=10/minute

# Maximum upload file size in MB
MAX_UPLOAD_SIZE_MB=100

# ── Application ───────────────────────────────────────────────────────────
# PyTorch device: cpu | cuda | mps
DEVICE=cpu

# MC Dropout passes (5 = fast, 100 = precise)
MC_PASSES=20

# Maximum rows to analyse (larger datasets are randomly sampled)
MAX_ROWS=10000

# ── PostgreSQL (used by docker-compose) ───────────────────────────────────
POSTGRES_DB=robustidps
POSTGRES_USER=robustidps
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
